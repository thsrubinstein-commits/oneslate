# OneSlate — environment / secrets reference
#
# The dashboard (index.html) has the Supabase URL + anon key compiled in already — those
# are safe to be public. The values below are for the GARMIN SYNC JOB only and must be
# added as GitHub repo secrets (Settings → Secrets and variables → Actions → New secret),
# NOT committed to the repo.

# --- Garmin auth (preferred: token; fallback: email/password) ---
# Generate locally with: python scripts/garmin_token.py
GARMIN_TOKEN_BASE64=
# Only used if no token is set (works for accounts WITHOUT MFA):
GARMIN_EMAIL=
GARMIN_PASSWORD=

# --- Supabase (server-side write access) ---
# Project URL, e.g. https://xspojczmywydubmttued.supabase.co  (no trailing /rest/v1)
SUPABASE_URL=
# service_role key — Supabase → Settings → API → "service_role" (SECRET, full access)
SUPABASE_SERVICE_KEY=
# Your auth user id — Supabase → Authentication → Users → click your user → "User UID"
SUPABASE_USER_ID=
